{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "verbos": {
      "format": "%(asctime)s - %(name)s - %(levelname)-8.8s - %(pathname)s:%(lineno)d - %(message)s",
      "datefmt": "%Y-%m-%d %H:%M:%S"
    },
    "simple": {
      "format": "%(asctime)s - %(levelname)-8.8s - %(message)s",
      "datefmt": "%Y-%m-%d %H:%M:%S"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "level": "INFO",
      "formatter": "simple",
      "stream": "ext://sys.stdout"
    },
    "rotating_file": {
      "class": "logging.handlers.RotatingFileHandler",
      "level": "DEBUG",
      "formatter": "verbos",
      "filename": "logs/app.log",
      "maxBytes": 10485760,
      "backupCount": 5,
      "encoding": "utf-8"
    }
  },
  "root": {
    "level": "DEBUG",
    "handlers": ["console", "rotating_file"]
  },
  "loggers": {
    "some_module": {
      "level": "WARNING",
      "handlers": ["rotating_file"],
      "propagate": false
    }
  }
}
